# =============================================
# SMART-PAIE — Variables d'environnement Backend
# Copier ce fichier en .env et adapter les valeurs
# =============================================

# ── Serveur ──────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=https://localhost:3000

# ── Base de données PostgreSQL ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_paie_db
DB_USER=smart_paie_user
DB_PASSWORD=VotreMotDePasseSecurise123!
DB_SSL=false

# ── JWT (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGEZ_MOI_EN_PRODUCTION_64_CARACTERES_MINIMUM
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGEZ_MOI_EN_PRODUCTION_64_CARACTERES_MINIMUM_REFRESH
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── HTTPS local (mkcert) ──────────────────────
SSL_CERT_PATH=./ssl/localhost.pem
SSL_KEY_PATH=./ssl/localhost-key.pem
